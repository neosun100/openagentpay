{
  "name": "@openagentpay/demo-api",
  "version": "0.1.0-alpha.0",
  "description": "Local-dev Express HTTP server for OpenAgentPay demo (becomes Lambda Function URL in production).",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@openagentpay/wallet-hashkey": "workspace:*",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "@openagentpay/wallet-coinbase-cdp": "workspace:*",
    "@openagentpay/governance": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
