{
  "name": "@openagentpay/wallet-hedera",
  "version": "0.1.0-alpha.0",
  "description": "Hedera (HBAR + HTS USDC) wallet connector for OpenAgentPay — Ed25519, non-EVM, HCS-flavored transfer authorization.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["hedera", "hbar", "hts", "openagentpay", "non-evm", "ed25519"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
