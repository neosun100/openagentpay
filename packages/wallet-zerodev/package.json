{
  "name": "@openagentpay/wallet-zerodev",
  "version": "0.1.0-alpha.0",
  "description": "ZeroDev ERC-4337 smart-account wallet connector for OpenAgentPay — owner-EOA-signed UserOperations with on-chain spending limits + sponsored gas (x402-v1, USDC on Base Sepolia).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["zerodev", "erc-4337", "smart-account", "account-abstraction", "openagentpay", "evm", "base-sepolia", "sponsored-gas"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/hashes": "^1.8.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
