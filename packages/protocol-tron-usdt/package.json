{
  "name": "@openagentpay/protocol-tron-usdt",
  "version": "0.1.0-alpha.0",
  "description": "TRON USDT (TRC-20) protocol adapter — supports the largest stablecoin volume on earth. Pay merchants in USDT-TRC20 with EIP-712-style off-chain signing or TIP-712 typed-data signatures.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }, "./package.json": "./package.json" },
  "files": ["dist", "src"],
  "scripts": { "build": "tsc", "test": "vitest run", "typecheck": "tsc --noEmit", "clean": "rm -rf dist *.tsbuildinfo" },
  "keywords": ["tron", "usdt", "trc20", "openagentpay"],
  "dependencies": { "@openagentpay/core": "workspace:*" },
  "devDependencies": { "@openagentpay/conformance": "workspace:*", "typescript": "^5.5.0", "vitest": "^2.1.0" }
}
