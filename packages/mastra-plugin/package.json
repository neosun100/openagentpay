{
  "name": "@openagentpay/mastra-plugin",
  "version": "0.1.0-alpha.0",
  "description": "Mastra Tool integration for OpenAgentPay — TypeScript-first agent framework with autonomous payments.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["mastra", "openagentpay", "ai-agent", "payments", "x402", "ap2"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@openagentpay/governance": "workspace:*",
    "@openagentpay/llamaindex-plugin": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
