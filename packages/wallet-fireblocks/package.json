{
  "name": "@openagentpay/wallet-fireblocks",
  "version": "0.1.0-alpha.0",
  "description": "Fireblocks institutional MPC custody wallet connector for OpenAgentPay — EVM EIP-3009 over USDC on Base Sepolia, policy-engine governed.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["fireblocks", "mpc", "institutional", "custody", "openagentpay", "evm", "eip-3009", "x402"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/hashes": "^1.8.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
