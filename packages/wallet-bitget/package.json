{
  "name": "@openagentpay/wallet-bitget",
  "version": "0.1.0-alpha.0",
  "description": "Bitget Wallet Pay connector for OpenAgentPay. CEX-pay (HMAC-SHA256) wallet integration.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@openagentpay/protocol-cex-pay": "workspace:*"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["bitget", "bitget-wallet", "bitget-pay", "cex-pay", "wallet-connector"]
}
