{
  "name": "@openagentpay/protocol-x402",
  "version": "0.1.0-alpha.0",
  "description": "Coinbase x402 v1/v2 protocol adapter for OpenAgentPay — HTTP 402 + EIP-712 + EIP-3009 settlement.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src", "doc"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["x402", "eip-712", "eip-3009", "coinbase", "openagentpay"],
  "dependencies": {
    "@openagentpay/core": "workspace:*"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
