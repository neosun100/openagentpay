{
  "name": "@openagentpay/wallet-circle",
  "version": "0.1.0-alpha.0",
  "description": "Circle Programmable Wallets connector for OpenAgentPay — developer-controlled EVM wallets, USDC-native + gas-station, x402 / EIP-3009 transferWithAuthorization on Base Sepolia / Polygon Amoy / ETH Sepolia.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["circle", "programmable-wallets", "usdc", "gas-station", "evm", "x402", "eip-3009", "openagentpay", "wallet-connector"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/hashes": "^1.8.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
