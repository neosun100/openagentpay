{
  "name": "@openagentpay/wallet-tron",
  "version": "0.1.0-alpha.0",
  "description": "TRON (TRC-20 USDT) wallet connector for OpenAgentPay — secp256k1 + base58check, real testnet keys, offline-safe signing.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["tron", "trc20", "usdt", "openagentpay", "secp256k1", "base58check"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
