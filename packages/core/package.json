{
  "name": "@openagentpay/core",
  "version": "0.1.0-alpha.0",
  "description": "Core orchestrator and interface definitions for OpenAgentPay (WalletConnector, ProtocolAdapter, SessionManager).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },  "keywords": ["agentcore", "agent-payments", "interfaces"]
}
