{
  "name": "@openagentpay/wallet-stripe-privy",
  "version": "0.1.0-alpha.0",
  "description": "Stripe Privy managed embedded-wallet connector for OpenAgentPay — EVM secp256k1 + EIP-3009 (x402-v1), closes AgentCore Path-D parity for non-CDP managed wallets.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["stripe", "privy", "openagentpay", "evm", "eip-3009", "x402", "managed-wallet", "agentcore", "base-sepolia"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
