{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["bin/**/*", "lib/**/*"]
}
