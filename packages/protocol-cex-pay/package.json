{
  "name": "@openagentpay/protocol-cex-pay",
  "version": "0.1.0-alpha.0",
  "description": "OpenAgentPay Custom CEX Pay (OAP-CEX) v0.1 protocol adapter — for non-EIP-3009 CEX-internal payment rails.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
