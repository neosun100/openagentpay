{
  "name": "@openagentpay/wallet-magic",
  "version": "0.1.0-alpha.0",
  "description": "Magic.link wallet connector for OpenAgentPay — email-based EVM (secp256k1) wallet, EIP-3009 x402 signing on Base Sepolia USDC.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["magic", "magic-link", "openagentpay", "evm", "x402", "eip-3009", "base-sepolia", "email-wallet"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@openagentpay/conformance": "workspace:*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
