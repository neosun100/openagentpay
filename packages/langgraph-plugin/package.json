{
  "name": "@openagentpay/langgraph-plugin",
  "version": "0.1.0-alpha.0",
  "description": "LangGraph (Python AND TS) tool wrapper for OpenAgentPay — graph-based stateful agents with autonomous payments.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }, "./package.json": "./package.json" },
  "files": ["dist", "src"],
  "scripts": { "build": "tsc", "test": "vitest run", "typecheck": "tsc --noEmit", "clean": "rm -rf dist *.tsbuildinfo" },
  "keywords": ["langgraph", "openagentpay", "agent-payments"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "@openagentpay/governance": "workspace:*",
    "@openagentpay/llamaindex-plugin": "workspace:*"
  },
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.1.0" }
}
