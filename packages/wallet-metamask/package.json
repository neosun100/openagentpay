{
  "name": "@openagentpay/wallet-metamask",
  "version": "0.1.0-alpha.0",
  "description": "MetaMask (EIP-1193) wallet connector for OpenAgentPay — browser-mode self-custodial signing.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["metamask", "eip-1193", "wallet", "x402", "openagentpay"],
  "dependencies": {
    "@openagentpay/core": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
