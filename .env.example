# OpenAgentPay — environment variables for local development
# Copy this to `.env.local` (already gitignored) and fill in real values.
#
# Get these from https://merchant-test.binance.com (Sandbox tab) →
#   Developers → API Management → Create API Key

# --- Binance Pay (Sandbox) ---------------------------------------------------
BINANCE_PAY_API_KEY=your_sandbox_merchant_api_key_here
BINANCE_PAY_API_SECRET=your_sandbox_merchant_api_secret_here
BINANCE_PAY_MERCHANT_ID=your_8_digit_merchant_id_here

# Binance Pay does NOT have a separate sandbox host — sandbox is account-level.
BINANCE_PAY_BASE_URL=https://bpay.binanceapi.com

# Set to "true" to skip the interactive confirmation in scripts/binance-smoke.ts
BINANCE_PAY_SKIP_CONFIRM=false

# --- AWS (used by CDK in W3) -------------------------------------------------
AWS_REGION=us-west-2
AWS_PROFILE=default
